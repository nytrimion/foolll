{
    "name": "fulll/backend-fleet",
    "description": "Fleet management (DDD/CQRS) - Fulll technical test, exercise 2",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.5"
    },
    "autoload": {
        "psr-4": {
            "Fulll\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Fulll\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "behat": "behat",
        "phpstan": "phpstan analyse",
        "cs-fix": "php-cs-fixer fix",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "quality": [
            "@cs-check",
            "@phpstan",
            "@test",
            "@behat"
        ]
    },
    "config": {
        "sort-packages": true
    },
    "require-dev": {
        "behat/behat": "^3.31",
        "friendsofphp/php-cs-fixer": "^3.95",
        "phpstan/phpstan": "^2.2",
        "phpunit/phpunit": "^13.2"
    }
}
